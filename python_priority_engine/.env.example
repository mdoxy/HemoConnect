# ─────────────────────────────────────────────────────────────
# HemoConnect Priority Engine — Environment Variables
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# MongoDB — same Atlas cluster as the Node.js backend
MONGODB_URI=mongodb+srv://sshreyasmore7777_db_user:HBZFHUSQxYywlap7@cluster0.uouzmav.mongodb.net/Hemoconnect?appName=Cluster0
MONGODB_DB_NAME=Hemoconnect

# JWT Secret — must match the Node.js backend JWT_SECRET
JWT_SECRET=your_secret_key

# FastAPI server settings
HOST=0.0.0.0
PORT=8000

# CORS — allow the frontend and Node.js backend
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5000,http://127.0.0.1:5173,http://127.0.0.1:5000

# Escalation scheduler settings (overridden by DB rules, but used as fallback)
ESCALATION_INTERVAL_MINUTES=15
ESCALATION_THRESHOLD_MINUTES=30
ESCALATION_BOOST=5.0
